# ─────────────────────────────────────────────────────────────────────────────
# .env.example — commit this file. Never commit .env or secrets/
# Copy to .env and fill in real values for local dev.
# In production, values are injected via GitHub Actions secrets → K8s Secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:CHANGE_ME@postgres:5432/attendance_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── CompreFace ────────────────────────────────────────────────────────────────
COMPREFORE_URL=http://compreface-api:8080
COMPREFORE_API_KEY=CHANGE_ME
COMPREFORE_DETECTION_API_KEY=CHANGE_ME

# ── Twilio (SMS notifications) ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_PHONE_NUMBER=CHANGE_ME

# ── SendGrid (email notifications) ───────────────────────────────────────────
SENDGRID_API_KEY=CHANGE_ME
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── System ────────────────────────────────────────────────────────────────────
RECOGNITION_THRESHOLD=0.95
DUPLICATE_WINDOW_MINUTES=15

# ── Performance ───────────────────────────────────────────────────────────────
MJPEG_QUALITY=70
FRAME_RESIZE_WIDTH=640
FRAME_RESIZE_HEIGHT=480
CPU_THRESHOLD=80.0
MEMORY_THRESHOLD=90.0

# ── Next.js dashboard ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_PB_URL=http://localhost:8090

# ── PocketBase ────────────────────────────────────────────────────────────────
PB_ADMIN_EMAIL=CHANGE_ME
PB_ADMIN_PASSWORD=CHANGE_ME

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Get this from: https://one.dash.cloudflare.com → Zero Trust → Networks → Tunnels → Create tunnel
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME

# ── GlitchTip (error monitoring) ─────────────────────────────────────────────
# DSN from: https://app.glitchtip.com → your project → Settings → DSN
GLITCHTIP_DSN=https://ac3cf00c929b47dab37d4e23d69ff569@app.glitchtip.com/22231
NEXT_PUBLIC_GLITCHTIP_DSN=https://ac3cf00c929b47dab37d4e23d69ff569@app.glitchtip.com/22231
